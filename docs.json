{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Orchid",
  "colors": {
    "primary": "#89C4E1",
    "light": "#a8d4ea",
    "dark": "#5a9ab5"
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#ffffff",
      "dark": "#0a0a0a"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "light-plus",
        "dark": "dark-plus"
      }
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@orchid.ac"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Access",
      "href": "https://app.orchid.ac"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/quickstart",
              "getting-started/authentication",
              "getting-started/models"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/thinking-mode",
              "guides/hallucination-detection",
              "guides/tool-calling",
              "guides/max-tokens",
              "guides/webhooks"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/python",
              "integrations/javascript",
              "integrations/anthropic",
              "integrations/langchain",
              "integrations/cursor",
              "integrations/vercel-ai-sdk",
              "integrations/litellm"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/chat-completions",
              "api-reference/messages",
              "api-reference/models",
              "api-reference/rate-limits",
              "api-reference/usage",
              "api-reference/health",
              "api-reference/webhooks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.orchid.ac",
          "icon": "gauge",
          "color": {
            "light": "#1d4ed8",
            "dark": "#93c5fd"
          }
        },
        {
          "anchor": "Status",
          "href": "https://status.orchid.ac",
          "icon": "signal",
          "color": {
            "light": "#0c8ce9",
            "dark": "#38bdf8"
          }
        },
        {
          "anchor": "Support",
          "href": "mailto:hello@orchid.ac",
          "icon": "envelope",
          "color": {
            "light": "#64748b",
            "dark": "#a3d1ff"
          }
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "linkedin": "https://uk.linkedin.com/company/orchidtechnologies"
    }
  }
}
