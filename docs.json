{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Orchid",
  "colors": {
    "primary": "#c8a96e",
    "light": "#d4b87a",
    "dark": "#9a7d4a"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@orchid.ac"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Access",
      "href": "https://app.orchid.ac"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/quickstart",
              "getting-started/authentication",
              "getting-started/models"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/thinking-mode",
              "guides/hallucination-detection",
              "guides/tool-calling",
              "guides/max-tokens",
              "guides/webhooks"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/python",
              "integrations/javascript",
              "integrations/langchain",
              "integrations/cursor",
              "integrations/vercel-ai-sdk",
              "integrations/litellm"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/chat-completions",
              "api-reference/models",
              "api-reference/usage",
              "api-reference/webhooks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.orchid.ac",
          "icon": "gauge"
        },
        {
          "anchor": "Status",
          "href": "https://status.orchid.ac",
          "icon": "signal"
        },
        {
          "anchor": "Support",
          "href": "mailto:hello@orchid.ac",
          "icon": "envelope"
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "linkedin": "https://uk.linkedin.com/company/orchidtechnologies"
    }
  }
}
